{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dasafo_factory/prp_contract/v1.0",
  "title": "PRP Contract (Project Requirement Protocol)",
  "description": "Mandatory validation contract. The user declares WHAT and WHY before any code is written. No agent may advance past M1 without a validated PRP.",
  "type": "object",
  "required": [
    "contract_meta",
    "vision",
    "success_criteria",
    "constraints",
    "non_goals",
    "prp_status"
  ],
  "properties": {
    "contract_meta": {
      "type": "object",
      "required": ["project_id", "version", "created_by", "created_at"],
      "properties": {
        "project_id": {
          "type": "string",
          "description": "Unique project identifier (e.g., 'vibeboard', 'pulse-x')."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this contract (e.g., '1.0.0')."
        },
        "created_by": {
          "type": "string",
          "description": "Human author of the contract."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of creation."
        },
        "validated_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp of validation. Null until validated."
        },
        "validated_by": {
          "type": ["string", "null"],
          "description": "Agent ID that performed the final validation (e.g., 'PRODUCT_OWNER')."
        }
      }
    },
    "vision": {
      "type": "object",
      "required": ["what", "why", "who"],
      "properties": {
        "what": {
          "type": "string",
          "minLength": 20,
          "description": "Clear statement of WHAT the system must do. In the user's own words."
        },
        "why": {
          "type": "string",
          "minLength": 10,
          "description": "Business or personal motivation. WHY does this need to exist?"
        },
        "who": {
          "type": "string",
          "minLength": 5,
          "description": "Target users or audience. WHO will use this system?"
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "description": "Measurable acceptance criteria. Every criterion must be verifiable.",
      "items": {
        "type": "object",
        "required": ["id", "description", "metric", "threshold"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SC-\\d{3}$",
            "description": "Success criterion ID (e.g., 'SC-001')."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of what constitutes success."
          },
          "metric": {
            "type": "string",
            "description": "Quantifiable metric to measure (e.g., 'page_load_time_ms', 'user_can_login')."
          },
          "threshold": {
            "type": "string",
            "description": "Pass/fail boundary (e.g., '< 2000', 'true', '>= 95%')."
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "description": "Technical or business boundaries the system must respect.",
      "items": {
        "type": "object",
        "required": ["id", "description", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CON-\\d{3}$"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["technical", "business", "legal", "ethical"]
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "description": "What the system explicitly does NOT do. Prevents scope creep.",
      "items": {
        "type": "string"
      }
    },
    "prp_status": {
      "type": "string",
      "enum": ["draft", "validated", "locked"],
      "description": "Contract lifecycle: draft -> validated (user confirmed) -> locked (immutable, in production)."
    }
  }
}
