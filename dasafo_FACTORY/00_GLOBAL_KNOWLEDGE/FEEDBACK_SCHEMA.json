{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dasafo_factory/feedback_entry/v4.0-S",
  "title": "Feedback Log Entry Schema",
  "description": "Machine-parseable schema for FEEDBACK-LOG entries. Enables automated pre-flight checks and pattern analysis (Industrial Core v4.0-S).",
  "type": "object",
  "required": [
    "id",
    "version",
    "timestamp",
    "context",
    "severity",
    "error_description",
    "correction",
    "golden_rule",
    "categories"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^FB-\\d{4}$",
      "description": "Unique feedback entry ID (e.g., 'FB-0001')."
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+(\\.\\d+)?(-[A-Z]+)?$",
      "description": "Semantic version of the factory standard (e.g., 'v4.0-S' or 'v4.0-S')."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date-time when the error was discovered."
    },
    "context": {
      "type": "object",
      "required": [
        "agent",
        "project",
        "phase"
      ],
      "properties": {
        "agent": {
          "type": "string",
          "enum": [
            "ORCHESTRATOR",
            "MARKETING_GROWTH",
            "PRODUCT_OWNER",
            "ARCHITECT",
            "RESEARCH_AGENT",
            "BACKEND_DEV",
            "DB_MASTER",
            "FRONTEND_DEV",
            "DOCS_MASTER",
            "QA_TESTER",
            "SECURITY_AUDITOR",
            "FACTORY_EVOLVER",
            "MEMORY_OPTIMIZER"
          ],
          "description": "Authorized Agent ID from v4.0-S Industrial Mapping."
        },
        "project": {
          "type": "string",
          "description": "Project where the error occurred (e.g., 'ContentRepurpose')."
        },
        "phase": {
          "type": "string",
          "enum": [
            "M1_DISCOVERY",
            "M2_ARCHITECTURE",
            "M3_PRODUCTION",
            "M4_COMPLIANCE",
            "M5_OPERATIONS"
          ],
          "description": "The exact lifecycle phase where the error occurred."
        },
        "task_id": {
          "type": "string",
          "pattern": "^M[1-5]-\\d{3}$",
          "description": "Specific Task ID associated with the error (e.g., 'M3-001')."
        },
        "file": {
          "type": "string",
          "description": "Specific file where the error was found."
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "description": "Impact severity. Critical = security/data-loss. High = broken functionality. Medium = degraded quality. Low = cosmetic."
    },
    "error_description": {
      "type": "string",
      "description": "Precise, technical description of the error."
    },
    "correction": {
      "type": "string",
      "description": "Exact correction applied to resolve the error."
    },
    "golden_rule": {
      "type": "string",
      "description": "Universal rule derived from this error."
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "authentication",
          "routing",
          "database",
          "deployment",
          "security",
          "ui-ux",
          "api",
          "configuration",
          "testing",
          "performance",
          "data-integrity",
          "dependency",
          "infrastructure",
          "solidity-guard",
          "zero-trust",
          "containerization",
          "mcp-bridge",
          "hallucination",
          "atomic-vibe",
          "secret-leak",
          "scaffolding"
        ]
      },
      "description": "Category tags for automated pattern analysis."
    }
  }
}