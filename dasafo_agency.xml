                        <div class="w-2 h-2 rounded-full ${task.status === 'COMPLETED' ? 'bg-green-500' : 'bg-blue-500'}"></div>
                    </div>
                </div>
            `;
        }

        async function updateDashboard() {
            const start = performance.now();
            try {
                const res = await fetch('/api/data');
                const data = await res.json();

                // Connection Indicator
                document.getElementById('conn-indicator').classList.replace('bg-red-500', 'bg-green-500');

                // Header Metrics
                if (data.state) {
                    document.getElementById('project-objective').innerText = data.state.objective || 'Monitoring DAST assets...';
                    document.getElementById('project-phase').innerText = `${data.state.current_phase || 'M?'} / ${data.state.project_status || 'NOMINAL'}`;
                }

                // Render Columns
                const colHTML = { PENDING: '', IN_PROGRESS: '', COMPLETED: '' };
                const counts = { PENDING: 0, IN_PROGRESS: 0, COMPLETED: 0 };

                (data.registry || []).forEach(task => {
                    const status = task.status === 'COMPLETED' ? 'COMPLETED' : (task.status === 'IN_PROGRESS' ? 'IN_PROGRESS' : 'PENDING');
                    colHTML[status] += createTaskCard(task);
                    counts[status]++;
                });

                ['PENDING', 'IN_PROGRESS', 'COMPLETED'].forEach(s => {
                    document.getElementById(`col-${s.toLowerCase().replace('_', '')}`).innerHTML = colHTML[s] || '<div class="text-[10px] text-gray-700 italic p-2">No items.</div>';
                    document.getElementById(`count-${s.toLowerCase().replace('_', '')}`).innerText = counts[s];
                });

                // Latency display (SI Units)
                const lat = (performance.now() - start) / 1000;
                document.getElementById('latency-val').innerText = `${lat.toFixed(4)}s`;

            } catch (err) {
                document.getElementById('conn-indicator').classList.replace('bg-green-500', 'bg-red-500');
                console.error("DAST Stream Interrupted:", err);
            }
        }

        setInterval(updateDashboard, 5000);
        updateDashboard();
    </script>
