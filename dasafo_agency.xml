                    <div class="flex justify-between items-start mb-2">
                        <span class="text-[10px] font-mono text-gray-600">${task.id}</span>
                        <span class="text-[10px] font-bold text-gray-500">${task.phase || 'M?'}</span>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-200 leading-tight mb-3">${task.title || 'Untitled Task'}</h3>
