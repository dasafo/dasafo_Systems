  # 📊 Observability Node (Glances)
  health-monitor:
    image: nicolargo/glances:latest
    container_name: dasafo-health-monitor
    ports:
      - "61208:61208"
    environment:
      - GLANCES_OPT=-w
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - dasafo_network
    deploy:
      resources:
        limits:
          memory: 512M

networks:
  dasafo_network:
    name: dasafo_network
    driver: bridge

volumes:
